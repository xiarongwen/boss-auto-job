    "苏州": "101190400", "天津": "101030100", "重庆": "101040100",
}

MATCH_KEYWORDS = [
    "React", "TypeScript", "AI", "Agent", "前端", "Vue", "Node.js", "Webpack",
    "工作流", "Copilot", "RAG", "大模型", "对话", "工作台", "低代码", "组件",
