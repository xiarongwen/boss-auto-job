]


# ============================================================
# Output helpers
# ============================================================

def log(icon, msg):
    ts = datetime.now().strftime('%H:%M:%S')
    print(f"[{ts}] {icon} {msg}", file=sys.stderr)


def err(msg):
    log("❌", msg)


def ok(msg):
    log("✅", msg)


def warn(msg):
    log("⚠️", msg)


def info(msg):
    log("📋", msg)


# ============================================================
# Core functions
# ============================================================

def search_jobs(query: str, city_code: str, pages: int = 1) -> list:
    """Search jobs using Camoufox."""
    import subprocess

    info(f'Searching "{query}" in {city_code}, {pages} page(s)...')

    # Reuse search_camoufox.py
    script = Path(__file__).parent / 'scripts' / 'search_camoufox.py'
    if not script.exists():
        # Fallback: inline Camoufox search
        return _search_inline(query, city_code, pages)

    result = subprocess.run(
        [sys.executable, str(script), query, f'--city={city_code}', f'--pages={str(pages)}'],
        capture_output=True, text=True, timeout=180
    )

    output = result.stdout + result.stderr

    if '===JOBS_JSON_START===' in output:
        start = output.index('===JOBS_JSON_START===') + len('===JOBS_JSON_START===')
        end = output.index('===JOBS_JSON_END===')
        try:
            jobs = json.loads(output[start:end].strip())
            ok(f'Found {len(jobs)} jobs')
            return jobs
        except json.JSONDecodeError:
            pass

    # Fallback
    return _search_inline(query, city_code, pages)


def _search_inline(query: str, city_code: str, pages: int) -> list:
    """Inline Camoufox search (no subprocess)."""
    from camoufox.sync_api import Camoufox

    all_jobs = []
    with Camoufox(humanize=True, geoip=True, os="macos", block_images=False) as browser:
        for page_num in range(1, pages + 1):
            page = browser.new_page()
            try:
                page.goto(
                    f"https://www.zhipin.com/web/geek/job?query={query}&city={city_code}&page={page_num}",
                    wait_until="domcontentloaded", timeout=20000
                )
                time.sleep(4)

                result = page.evaluate("""
                    (q) => fetch('/wapi/zpgeek/search/joblist.json?scene=1&query=' + encodeURIComponent(q)
                        + '&city=QUERY_CITY&page=QUERY_PAGE&pageSize=30')
                        .then(r => r.json())
                        .catch(e => ({error: e.message}))
                """.replace("QUERY_CITY", city_code).replace("QUERY_PAGE", str(page_num)), query)

                code = result.get("code")
                if code == 0:
                    jobs = result.get("zpData", {}).get("jobList", [])
                    ok(f'Page {page_num}: {len(jobs)} jobs')
                    for j in jobs:
                        all_jobs.append({
                            "job_id": j.get("encryptJobId") or j.get("jobId"),
                            "title": j.get("jobName", ""),
                            "company": j.get("brandName", ""),
                            "salary": j.get("salaryDesc", ""),
                            "location": f"{j.get('cityName', '')} {j.get('areaDistrict', '')}".strip(),
                            "experience": j.get("jobExperience", ""),
                            "degree": j.get("jobDegree", ""),
                            "skills": j.get("skills", []),
                            "boss_name": j.get("bossName", ""),
                            "boss_title": j.get("bossTitle", ""),
                        })
                elif code in (36, 32):
                    err(f'Code {code}: {result.get("message", "")} — STOP')
                    break
                else:
                    warn(f'Code {code}: {result.get("message", result.get("error", ""))[:60]}')
            except Exception as e:
                err(f'Exception: {e}')
            finally:
                try: page.close()
                except: pass
            if page_num < pages:
                time.sleep(5)

    seen = set()
    unique = []
    for j in all_jobs:
        if j["job_id"] not in seen:
            seen.add(j["job_id"])
            unique.append(j)
    ok(f'Total: {len(unique)} unique jobs')
    return unique


def match_jobs(jobs: list, resume: str, top_n: int = 10) -> list:
    """Score jobs against resume using keyword matching."""
    info(f'Matching {len(jobs)} jobs against resume ({len(resume)} chars)...')

    for j in jobs:
        score = 0
        title = j.get("title", "").lower()
        skills = " ".join(j.get("skills", [])).lower()
        combined = f"{title} {skills} {j.get('company', '')}".lower()

        for kw in MATCH_KEYWORDS:
            if kw.lower() in combined:
                score += 8
            if kw.lower() in resume.lower() and kw.lower() in combined:
                score += 5  # Bonus: both resume and job mention it

        # Experience match
        exp = j.get("experience", "")
        if "3-5" in exp or "经验不限" in exp:
            score += 15
        elif "5-10" in exp:
            score += 10
        elif "1-3" in exp:
            score += 5

        # Degree
        if "本科" in j.get("degree", "") or "学历不限" in j.get("degree", ""):
            score += 5

        # Frontend-specific bonus
        if any(kw.lower() in combined for kw in ["前端", "frontend", "react", "vue"]):
            score += 10

        j["match_score"] = min(score, 100)

    jobs.sort(key=lambda x: x.get("match_score", 0), reverse=True)
    return jobs[:top_n]


def send_greeting(job_id: str, greeting: str) -> dict:
    """Send greeting to a recruiter."""
    import subprocess

    script = Path(__file__).parent / 'scripts' / 'send_camoufox.py'
    if not script.exists():
        return {"success": False, "error": "send_camoufox.py not found"}

    result = subprocess.run(
        [sys.executable, str(script), job_id, greeting],
        capture_output=True, text=True, timeout=120
    )

    output = result.stdout + result.stderr
    if "消息发送成功" in output:
        return {"success": True}
    return {"success": False, "error": output[-200:]}


def load_resume() -> str:
    if RESUME_FILE.exists():
        return RESUME_FILE.read_text().strip()
    return ""


def print_jobs_table(jobs: list, show_score: bool = False):
    """Pretty-print jobs as a table."""
    print()
    print(f"{'#':>3}  {'Score' if show_score else '':>5}  {'Title':<40}  {'Company':<20}  {'Salary':<15}  {'Area'}")
    print("-" * 120)
    for i, j in enumerate(jobs):
        score = f"{j.get('match_score', 0):3d}" if show_score else ""
        title = j.get("title", "")[:38]
        company = j.get("company", "")[:18]
        salary = j.get("salary", "")[:13]
        location = j.get("location", "")
        emoji = "🔥" if show_score and j.get("match_score", 0) >= 60 else "  "
        print(f"{i+1:3d}  {score:>5}  {emoji}{title:<38}  {company:<20}  {salary:<15}  {location}")
    print()


def print_job_detail(j: dict, idx: int = 0):
    """Print detailed job info."""
    skills = ", ".join(j.get("skills", [])[:6]) or "无"
    score = j.get("match_score", "")
    score_str = f" [{score}分]" if score else ""
    emoji = "🔥" if score and score >= 60 else "✅" if score and score >= 40 else ""

    print(f"\n  {idx}. {emoji}{score_str} {j.get('title', '')}")
    print(f"     🏢 {j.get('company', '')}")
    print(f"     💰 {j.get('salary', '')}")
    print(f"     📍 {j.get('location', '')} | 📋 {j.get('experience', '')} | {j.get('degree', '')}")
    print(f"     🛠️ {skills}")
    print(f"     👤 {j.get('boss_name', '')} ({j.get('boss_title', '')})")
    print(f"     🔑 {j.get('job_id', '')}")


