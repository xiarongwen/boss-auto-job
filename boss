# CLI
# ============================================================

def cmd_search(args):
    """Search and optionally match/send."""
    city_code = CITY_CODES.get(args.city, args.city)
    if not city_code or len(city_code) < 5:
        # Try direct code
        city_code = args.city

    jobs = search_jobs(args.query, city_code, args.pages)

    if not jobs:
        err("No jobs found")
        sys.exit(1)

    # Area filter
    if args.area:
        jobs = [j for j in jobs if args.area in j.get("location", "")]
        info(f'Filtered to {len(jobs)} jobs in {args.area}')

    if not jobs:
        err(f"No jobs found in {args.area}")
        sys.exit(1)

    # Match
    if args.match:
        resume = load_resume()
        if not resume:
            err("No resume found. Create ~/.hermes/credentials/resume.txt")
            sys.exit(1)
        jobs = match_jobs(jobs, resume, args.top or 10)
        print_jobs_table(jobs, show_score=True)
        for i, j in enumerate(jobs):
            print_job_detail(j, i + 1)
    else:
        print_jobs_table(jobs[:args.top or 20])

    # Send
    if args.send:
        if not args.match:
            warn("--send requires --match to rank jobs first")
            return

        sent = 0
        for j in jobs[:args.send_limit or 3]:
            # Generate simple greeting
            resume = load_resume()
            greeting = f"您好！{resume[:50]}对贵司{j.get('title', '')}岗位很感兴趣，方便进一步沟通吗？"
            info(f'Sending to {j.get("company", "")} ({j.get("boss_name", "")})...')
            result = send_greeting(j["job_id"], greeting)
            if result.get("success"):
                ok(f'Sent to {j.get("company", "")}')
                sent += 1
            else:
                err(f'Failed: {result.get("error", "")[:60]}')
            time.sleep(5)

        ok(f'Done! Sent {sent}/{min(len(jobs), args.send_limit or 3)} greetings')

    # Output JSON
    if args.json:
        print(json.dumps(jobs, ensure_ascii=False, indent=2))


def cmd_send(args):
    """Send a specific greeting."""
    result = send_greeting(args.job_id, args.message)
    if result.get("success"):
        ok("Greeting sent!")
    else:
        err(f"Failed: {result.get('error', '')}")


def cmd_resume(args):
    """Show resume."""
    resume = load_resume()
    if resume:
        print(resume)
    else:
        err(f"No resume found at {RESUME_FILE}")
        info("Create it with: echo 'your resume' > ~/.hermes/credentials/resume.txt")


def cmd_cities(args):
    """Show city codes."""
    print("\nCity codes for BOSS Zhipin:\n")
    for name, code in CITY_CODES.items():
        print(f"  {name:6s}  {code}")
    print()


def main():
    parser = argparse.ArgumentParser(
        prog='boss',
        description='Boss Auto Job - BOSS直聘自动求职工具 (Camoufox stealth)',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  boss search "产品经理" --city 深圳 --area 南山
  boss search "AI前端" --city 深圳 --match --top 5
  boss search "Agent开发" --match --send --top 3
  boss send <job_id> "你好，我对这个职位很感兴趣"
  boss resume
  boss cities
        """
    )
    sub = parser.add_subparsers(dest='command', help='Available commands')

    # search
    p_search = sub.add_parser('search', help='Search jobs on BOSS Zhipin')
    p_search.add_argument('query', help='Job keyword')
    p_search.add_argument('--city', default='深圳', help='City name or code (default: 深圳)')
    p_search.add_argument('--area', help='Filter by district, e.g. 南山')
    p_search.add_argument('--pages', type=int, default=1, help='Pages to search (default: 1)')
    p_search.add_argument('--match', action='store_true', help='Match against resume')
    p_search.add_argument('--top', type=int, default=10, help='Top N results (default: 10)')
    p_search.add_argument('--send', action='store_true', help='Send greetings to top matches')
    p_search.add_argument('--send-limit', type=int, default=3, help='Max greetings to send (default: 3)')
    p_search.add_argument('--json', action='store_true', help='Output JSON')
    p_search.set_defaults(func=cmd_search)

    # send
    p_send = sub.add_parser('send', help='Send a greeting to a recruiter')
    p_send.add_argument('job_id', help='encryptJobId from search results')
    p_send.add_argument('message', help='Greeting message')
    p_send.set_defaults(func=cmd_send)

    # resume
    p_resume = sub.add_parser('resume', help='Show current resume')
    p_resume.set_defaults(func=cmd_resume)

    # cities
    p_cities = sub.add_parser('cities', help='Show available city codes')
    p_cities.set_defaults(func=cmd_cities)

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(0)

    args.func(args)


if __name__ == '__main__':
    main()
